{
  "title": "Viscacha",
  "uid": "viscacha-jobs",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["viscacha"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "5s",
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Pending",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 0,  "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_jobs{status=\"pending\"}",
          "instant": true,
          "legendFormat": "pending"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Active (claimed)",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 4,  "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_jobs{status=\"claimed\"}",
          "instant": true,
          "legendFormat": "active"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Done",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 8,  "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_jobs{status=\"done\"}",
          "instant": true,
          "legendFormat": "done"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Failed",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_jobs{status=\"failed\"}",
          "instant": true,
          "legendFormat": "failed"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1    }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Cancelled",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_jobs{status=\"cancelled\"}",
          "instant": true,
          "legendFormat": "cancelled"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "gray" },
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Retried",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_retried_jobs",
          "instant": true,
          "legendFormat": "retried"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1    }
            ]
          }
        }
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Job counts by status",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_jobs{status=\"pending\"}",
          "legendFormat": "pending"
        },
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_jobs{status=\"claimed\"}",
          "legendFormat": "active"
        },
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_jobs{status=\"done\"}",
          "legendFormat": "done"
        },
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_jobs{status=\"failed\"}",
          "legendFormat": "failed"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pending" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "active" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          },
          {
            "matcher": { "id": "byName", "options": "done" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Queue wait time",
      "description": "Time jobs spend waiting in queue before a worker claims them. Percentiles computed over all jobs in memory.",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "histogram_quantile(0.50, viscacha_queue_wait_seconds_bucket)",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "histogram_quantile(0.95, viscacha_queue_wait_seconds_bucket)",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "histogram_quantile(0.99, viscacha_queue_wait_seconds_bucket)",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Execution time",
      "description": "Time from job claim to completion or failure. Percentiles computed over all finished jobs in memory.",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "histogram_quantile(0.50, viscacha_exec_seconds_bucket)",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "histogram_quantile(0.95, viscacha_exec_seconds_bucket)",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "histogram_quantile(0.99, viscacha_exec_seconds_bucket)",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },

    {
      "id": 10,
      "type": "heatmap",
      "title": "Execution time heatmap",
      "description": "Distribution of job execution times over time. Brighter = more jobs completed in that duration bucket.",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "sum(increase(viscacha_exec_seconds_bucket[1m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "mode": "scheme",
          "scheme": "Greens",
          "steps": 64
        },
        "yAxis": { "unit": "s", "decimals": 3 }
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Jobs by worker",
      "description": "Requires jobs to be claimed with a worker_id in the request body.",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_worker_jobs{status=\"done\"}",
          "legendFormat": "{{worker_id}} done"
        },
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_worker_jobs{status=\"claimed\"}",
          "legendFormat": "{{worker_id}} active"
        },
        {
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_worker_jobs{status=\"failed\"}",
          "legendFormat": "{{worker_id}} failed"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } }
      }
    },

    {
      "id": 12,
      "type": "table",
      "title": "Job trace",
      "description": "All jobs in memory with worker attribution and timing.",
      "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "start",
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_job_start_seconds * 1000",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        },
        {
          "refId": "end",
          "datasource": { "type": "prometheus", "uid": "viscacha-prometheus" },
          "expr": "viscacha_job_end_seconds * 1000",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #start": "started_at",
              "Value #end":   "ended_at",
              "job_id":       "job id",
              "job_type":     "type",
              "worker_id":    "worker",
              "status":       "status"
            },
            "excludeByName": {
              "Time":              true,
              "Time #start":       true,
              "Time #end":         true,
              "__name__":          true,
              "__name__ #start":   true,
              "__name__ #end":     true,
              "instance":          true,
              "instance #start":   true,
              "instance #end":     true,
              "job":               true,
              "job #start":        true,
              "job #end":          true
            },
            "indexByName": {
              "job id":     0,
              "type":       1,
              "worker":     2,
              "status":     3,
              "started_at": 4,
              "ended_at":   5
            }
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              { "targetField": "started_at", "destinationType": "time" },
              { "targetField": "ended_at",   "destinationType": "time" }
            ]
          }
        }
      ],
      "options": { "sortBy": [{ "displayName": "started_at", "desc": true }] },
      "dataLinks": [
        {
          "title": "Inspect job",
          "url": "http://localhost:8000/dashboard#job=${__data.fields[\"job id\"]}",
          "targetBlank": true
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "pending":   { "color": "blue",   "index": 0 } } },
                  { "type": "value", "options": { "claimed":   { "color": "yellow", "index": 1 } } },
                  { "type": "value", "options": { "done":      { "color": "green",  "index": 2 } } },
                  { "type": "value", "options": { "failed":    { "color": "red",    "index": 3 } } },
                  { "type": "value", "options": { "cancelled": { "color": "gray",   "index": 4 } } }
                ]
              }
            ]
          }
        ]
      }
    }

  ]
}
